<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">

<!--
    TestNG Suite Configuration
    ==========================
    Run with: mvn test -Ptestng

    Parallel modes:
      - parallel="methods"   : each test method runs in separate thread
      - parallel="tests"     : each <test> block in separate thread
      - parallel="classes"   : each class in separate thread
      - parallel="none"      : sequential execution

    Thread count: adjust based on available CPU cores and browser instances.
    Recommended for local: 2-4 threads
    Recommended for Docker Selenium Grid: match grid node count
-->

<suite name="Final Project Bootcamp Group 2 — Test Suite"
       verbose="1"
       parallel="methods"
       thread-count="4"
       data-provider-thread-count="4">

    <!-- ================================================================ -->
    <!--  System Properties passed to all tests                            -->
    <!-- ================================================================ -->
    <parameter name="browser"  value="chrome"/>
    <parameter name="headless" value="false"/>
    <parameter name="env"      value="dev"/>

    <!-- ================================================================ -->
    <!--  Listeners                                                         -->
    <!-- ================================================================ -->
    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <!-- ================================================================ -->
    <!--  All Tests (default)                                               -->
    <!-- ================================================================ -->
    <test name="All Feature Tests" preserve-order="true">
        <classes>
            <class name="com.bootcamp.group2.runners.testng.TestNGRunner"/>
        </classes>
    </test>

</suite>
